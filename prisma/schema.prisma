generator client {
  provider = "prisma-client"
  output   = "../src/lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  TEACHER
  STUDENT
  PARENT
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          Role      @default(STUDENT)
  phone         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts Account[]
  sessions Session[]
  faculty  Faculty?
  student  Student?

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Campus {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  location    String
  phone       String?
  email       String?
  students    String?
  faculty     String?
  description String?  @db.Text
  programs    String?
  facilities  String[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  enrollments Student[]
  applications Admission[]

  @@map("campuses")
}

model Department {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())

  members Faculty[]

  @@map("departments")
}

model Program {
  id        String   @id @default(cuid())
  level     String
  name      String
  duration  String?
  createdAt DateTime @default(now())

  enrollments Student[]
  applications Admission[]

  @@map("programs")
}

model Faculty {
  id            String   @id @default(cuid())
  userId        String   @unique
  name          String
  role          String
  qualification String?
  experience    String?
  departmentId  String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user       User       @relation(fields: [userId], references: [id])
  department Department? @relation(fields: [departmentId], references: [id])

  @@map("faculty")
}

model Student {
  id             String   @id @default(cuid())
  userId         String   @unique
  name           String
  fatherName     String?
  dateOfBirth    DateTime?
  gender         String?
  phone          String?
  address        String?
  previousSchool String?
  campusId       String?
  programId      String?
  enrollmentYear String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user    User     @relation(fields: [userId], references: [id])
  campus  Campus?  @relation(fields: [campusId], references: [id])
  program Program? @relation(fields: [programId], references: [id])

  @@map("students")
}

model Admission {
  id             String   @id @default(cuid())
  applicationId  String   @unique
  studentName    String
  fatherName     String
  cnicBform      String
  dateOfBirth    String?
  gender         String
  mobileNumber   String
  email          String?
  address        String
  previousSchool String?
  campusId       String
  programId      String
  status         String   @default("Submitted")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  campus  Campus  @relation(fields: [campusId], references: [id])
  program Program @relation(fields: [programId], references: [id])

  @@map("admissions")
}

model News {
  id        String   @id @default(cuid())
  title     String
  date      String
  category  String
  excerpt   String   @db.Text
  content   String?  @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("news")
}

model Event {
  id          String   @id @default(cuid())
  title       String
  date        String
  description String   @db.Text
  createdAt   DateTime @default(now())

  @@map("events")
}

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  subject   String?
  message   String   @db.Text
  createdAt DateTime @default(now())

  @@map("contact_messages")
}

model QualityPolicy {
  id          String   @id @default(cuid())
  title       String
  description String   @db.Text
  icon        String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("quality_policies")
}

model SARReport {
  id      String @id @default(cuid())
  program String
  year    String
  status  String
  type    String

  @@map("sar_reports")
}

model Accreditation {
  id         String   @id @default(cuid())
  body       String
  status     String
  programs   String[]
  validUntil String
  createdAt  DateTime @default(now())

  @@map("accreditations")
}

model GalleryItem {
  id        String   @id @default(cuid())
  title     String
  category  String
  imageUrl  String?
  createdAt DateTime @default(now())

  @@map("gallery_items")
}

model Download {
  id        String   @id @default(cuid())
  category  String
  name      String
  fileUrl   String?
  createdAt DateTime @default(now())

  @@map("downloads")
}
